# Deploy environment variables
# Copy to deploy.env and fill in real values.
# NEVER commit deploy.env with real hostnames/credentials.

# Backend
BACKEND_BASE_URL=http://<BACKEND_HOST>:<PORT>

# Portal
PORTAL_BASE_URL=http://<PORTAL_HOST>:<PORT>

# PostgreSQL (for preflight checks)
PGHOST=<POSTGRES_HOST>
PGPORT=5432
PGUSER=<USER>

# Deployment
DEPLOY_ENV=<local|dev|stage|prod>
DEPLOY_APPROVAL=<APPROVER_NAME>

# Rollback
TARGET_COMMIT=<COMMIT_SHA>
ROLLBACK_APPROVAL=<APPROVER_NAME>
LAST_BACKUP_FILE=/backups/pg/<BACKUP_FILENAME>
