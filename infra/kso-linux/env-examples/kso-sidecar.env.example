# KSO Sidecar Agent — Environment
# Copy to /etc/verny/kso/sidecar.env and fill in real values.
# Permissions: chmod 600, owner root:verny

# Backend base URL (e.g. https://kso-backend.example.com)
VERNY_KSO_BACKEND_URL=https://backend.example

# Device code for auth
VERNY_KSO_DEVICE_CODE=CHANGE_ME

# Device secret — MUST be set via env, never passed as CLI argument
VERNY_KSO_DEVICE_SECRET=CHANGE_ME_SECRET
