# KSO State Adapter — Environment
# Copy to /etc/verny/kso/state-adapter.env and fill in real values.
# Permissions: chmod 600, owner root:verny

# Source type: "static" (default, safe) or "file" (future UKM 4 integration)
VERNY_KSO_STATE_SOURCE=static

# Static state (used when VERNY_KSO_STATE_SOURCE=static)
VERNY_KSO_STATIC_STATE=unknown
# ⚠ unknown = safe default: player will HOLD (no ads).
# Use "idle" ONLY for local testing — never in production.

# File source path (used when VERNY_KSO_STATE_SOURCE=file)
VERNY_KSO_SOURCE_FILE=/run/verny/kso/ukm4-safe-state.json
# File MUST:
#  - Be under /run/verny/kso/ or /var/lib/verny/kso/
#  - Be ≤ 1024 bytes
#  - Contain ONLY {"state":"idle"} or plain idle
#  - NEVER contain: checks, payments, SKUs, cards, PII, fiscal data
