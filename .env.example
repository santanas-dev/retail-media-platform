# Retail Media Platform - Environment Configuration
# Copy to .env and adjust for your environment

# Application
APP_NAME=Retail Media Platform
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-in-production

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=retail_media
POSTGRES_PASSWORD=retail_media_dev
POSTGRES_DB=retail_media_platform

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=retail_media_analytics

# MinIO
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=retail-media
MINIO_SECURE=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Identity — initial admin user (created by seed script)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-in-production
INITIAL_ADMIN_EMAIL=admin@localhost
