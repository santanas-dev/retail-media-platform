# Retail Media Platform — Environment Configuration
# Copy to .env and adjust for your environment

# ── Application ──────────────────────────────────────────────────
APP_NAME=Retail Media Platform
APP_VERSION=0.1.0
APP_ENV=development                 # development | staging | production
DEBUG=true
# Generate a long random string: openssl rand -hex 32
SECRET_KEY=replace-with-random-secret-at-least-32-chars

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=retail_media
POSTGRES_PASSWORD=retail_media_dev
POSTGRES_DB=retail_media_platform

# ── ClickHouse ──────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=retail_media_analytics

# ── MinIO (development only — minioadmin/minioadmin) ────────────
# WARNING: these credentials are for local development only.
# For staging/production, change to strong random values.
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=retail-media
MINIO_SECURE=false

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Initial admin (used by identity seed) ───────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_EMAIL=admin@localhost
